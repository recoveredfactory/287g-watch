# Web app
WEB_DOMAIN=287g.yourdomain.com
WEB_STAGING_DOMAIN=staging.287g.yourdomain.com

# Data CDN (prod only — for local dev, data lives in packages/web/static/data)
DATA_BUCKET_NAME=your-s3-bucket-name
DATA_BUCKET_REGION=us-east-2
DATA_CDN_DOMAIN=data.287g.yourdomain.com

# Set this to point the web app at the CDN (prod) or leave blank to use local static files
PUBLIC_DATA_BASE_URL=
PUBLIC_DATA_RELEASE_PATH=/releases/v1
