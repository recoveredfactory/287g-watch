# Copy to .env and fill in. Only the data pipeline + dev server need anything
# here, and even GITHUB_TOKEN is optional. The deploy/social vars are for
# maintainers running SST and the social-publish scripts.

# --- Data pipeline (pnpm pipeline) -------------------------------------------
# Read-only GitHub token. Optional: raises the GitHub API rate limit from
# 60 to 5,000 req/hr. The pipeline runs unauthenticated without it, just slower.
GITHUB_TOKEN=

# --- News summaries (pnpm news; maintainers only) ----------------------------
# PromptQL Execute Program endpoint + Personal Access Token for the
# news_287g_state_summary saved program. The full /run URL goes in PQL_NEWS_URL.
PQL_NEWS_URL=
PQL_NEWS_TOKEN=

# --- Deploy: custom domains per stage (sst deploy) ---------------------------
WEB_DOMAIN=287g.yourdomain.com
WEB_STAGING_DOMAIN=staging.287g.yourdomain.com

# --- Email notifications (SES; maintainers only) -----------------------------
# Sender must be a verified SES identity. See docs/SOCIAL_UPLOAD.md.
NOTIFY_EMAIL_FROM=alerts@yourdomain.com
NOTIFY_EMAIL_TO=you@yourdomain.com

# --- Social auto-publish (maintainers only) ----------------------------------
# YouTube (OAuth) and Instagram (Graph API). See docs/SOCIAL_UPLOAD.md for how
# to obtain these. Leave blank unless you're wiring up the social pipeline.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
