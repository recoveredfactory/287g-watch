{
  "name": "287g-explorer",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "sst dev",
    "dev:web": "pnpm -F web dev",
    "deploy:staging": "sst deploy --stage staging",
    "deploy:prod": "sst deploy --stage prod",
    "diff:staging": "sst diff --stage staging",
    "diff:prod": "sst diff --stage prod",
    "remove:staging": "sst remove --stage staging",
    "pipeline": "pnpm -F pipeline ingest",
    "publish:map-assets:staging": "sst shell --stage staging node packages/web/scripts/publish-map-assets.mjs",
    "publish:map-assets:prod": "sst shell --stage prod node packages/web/scripts/publish-map-assets.mjs",
    "publish:og:staging": "sst shell --stage staging node packages/web/scripts/publish-og.mjs",
    "publish:og:prod": "sst shell --stage prod node packages/web/scripts/publish-og.mjs"
  },
  "devDependencies": {
    "sst": "^3.17.25"
  }
}
